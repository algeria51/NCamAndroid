<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#1565C0">

        <Button
            android:id="@+id/tabControl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Control"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/tabConsole"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Console"
            android:textColor="#BBDEFB"
            android:background="#1565C0"
            android:textSize="14sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FF6F00"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/pageControl"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:text="NCam"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#1565C0"
                android:layout_marginBottom="24dp"
                android:text=""/>

            <Button
                android:id="@+id/btnStart"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Start NCam"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Stop NCam"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnOpenBrowser"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Open WebIF"
                android:enabled="false"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/pageConsole"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#0D0D0D">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NCam Log"
                    android:textColor="#00FF7F"
                    android:textSize="13sp"
                    android:fontFamily="monospace"/>

                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="#333333"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:background="#0D0D0D">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textColor="#00FF7F"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:text=""/>
            </ScrollView>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
